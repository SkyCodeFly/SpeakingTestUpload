PORT=3000

# When the frontend is published on GitHub Pages, set this to your Pages URL.
# Example: https://yourname.github.io/speaking-test-upload
CORS_ORIGIN=

# Google Drive folder ID where student subfolders will be created.
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Service account credentials. Share the parent Drive folder with this email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Alternative to GOOGLE_PRIVATE_KEY:
# GOOGLE_PRIVATE_KEY_FILE=C:\path\to\service-account.json

# Alternative auth for uploading to a teacher's regular My Drive folder.
# If these three values are present, the app uses OAuth instead of service account.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# OpenAI API key for AI pronunciation/read-aloud evaluation.
OPENAI_API_KEY=
